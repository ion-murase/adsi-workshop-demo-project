{
  "name": "attendance-demo",
  "private": true,
  "scripts": {
    "boot": "cd packages/backend && ./gradlew bootRun",
    "boot:workshop": "cd packages/backend && ./gradlew bootRun --args='--spring.profiles.active=workshop'",
    "dev": "cd packages/frontend && npm run dev",
    "dev:sagemaker": "bash scripts/dev-sagemaker.sh",
    "build:backend": "cd packages/backend && ./gradlew bootJar",
    "build:frontend": "cd packages/frontend && npm run build",
    "check:backend": "cd packages/backend && ./gradlew check",
    "lint:frontend": "cd packages/frontend && npm run lint",
    "test:backend": "cd packages/backend && ./gradlew test",
    "db:up": "cd packages/backend && podman compose up -d",
    "db:down": "cd packages/backend && podman compose down",
    "deploy:dev": "cd packages/infra && npx cdk deploy --context env=dev",
    "deploy:prod": "cd packages/infra && npx cdk deploy --context env=prod",
    "synth": "cd packages/infra && npx cdk synth --context env=dev"
  }
}
